{
  "name": "@effect-desktop/core",
  "version": "2.0.0",
  "private": true,
  "description": "Effect-first runtime primitives, services, resources, permissions, telemetry, and storage for Effect Desktop.",
  "license": "MIT OR Apache-2.0",
  "author": "Rika Labs, LLC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rika-Labs/effect-desktop.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Rika-Labs/effect-desktop#readme",
  "bugs": {
    "url": "https://github.com/Rika-Labs/effect-desktop/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./renderer": {
      "types": "./src/runtime/renderer.ts",
      "default": "./src/runtime/renderer.ts"
    },
    "./inspector-transport": {
      "types": "./src/runtime/inspector-transport.ts",
      "default": "./src/runtime/inspector-transport.ts"
    },
    "./providers/bun": {
      "types": "./src/providers/bun.ts",
      "default": "./src/providers/bun.ts"
    },
    "./providers/node": {
      "types": "./src/providers/node.ts",
      "default": "./src/providers/node.ts"
    },
    "./providers/test": {
      "types": "./src/providers/test.ts",
      "default": "./src/providers/test.ts"
    },
    "./runtime/event-log": null,
    "./runtime/reactivity": null,
    "./runtime/workflow": null,
    "./runtime/*": {
      "types": "./src/runtime/*.ts",
      "default": "./src/runtime/*.ts"
    }
  },
  "scripts": {
    "check": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@effect-desktop/bridge": "workspace:*",
    "@effect/opentelemetry": "4.0.0-beta.60",
    "@effect/platform-bun": "4.0.0-beta.60",
    "@effect/platform-node": "4.0.0-beta.60",
    "@effect/sql-sqlite-bun": "4.0.0-beta.60",
    "@opentelemetry/api": "^1.9",
    "@opentelemetry/resources": "^2.0.0",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "@opentelemetry/sdk-metrics": "^2.0.0",
    "@opentelemetry/sdk-trace-base": "^2.0.0",
    "@opentelemetry/sdk-trace-node": "^2.0.0",
    "@opentelemetry/sdk-trace-web": "^2.0.0",
    "effect": "4.0.0-beta.60"
  }
}
