{
  "name": "@effect-desktop/test",
  "version": "2.0.0",
  "private": true,
  "description": "Headless runtime, mock host, mock bridge, and in-memory adapters for Effect Desktop tests.",
  "license": "MIT OR Apache-2.0",
  "author": "Rika Labs, LLC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rika-Labs/effect-desktop.git",
    "directory": "packages/test"
  },
  "homepage": "https://github.com/Rika-Labs/effect-desktop#readme",
  "bugs": {
    "url": "https://github.com/Rika-Labs/effect-desktop/issues"
  },
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./bridge": {
      "types": "./src/bridge.ts",
      "default": "./src/bridge.ts"
    },
    "./core": {
      "types": "./src/core.ts",
      "default": "./src/core.ts"
    },
    "./native": {
      "types": "./src/native.ts",
      "default": "./src/native.ts"
    },
    "./renderer": {
      "types": "./src/renderer.ts",
      "default": "./src/renderer.ts"
    }
  },
  "scripts": {
    "check": "tsgo --noEmit -p tsconfig.json",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "bun test",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@effect-desktop/bridge": "workspace:*",
    "@effect-desktop/core": "workspace:*",
    "@effect-desktop/native": "workspace:*",
    "effect": "4.0.0-beta.60"
  }
}
