{
  "name": "@effect-desktop/cli",
  "version": "2.0.0",
  "private": true,
  "description": "Developer CLI for Effect Desktop build, validation, packaging, signing, publishing, and diagnostics.",
  "license": "MIT OR Apache-2.0",
  "author": "Rika Labs, LLC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rika-Labs/effect-desktop.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Rika-Labs/effect-desktop#readme",
  "bugs": {
    "url": "https://github.com/Rika-Labs/effect-desktop/issues"
  },
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "desktop": "src/bin.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "check": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@effect-desktop/bridge": "workspace:*",
    "@effect-desktop/config": "workspace:*",
    "@effect-desktop/core": "workspace:*",
    "@effect/platform-bun": "4.0.0-beta.60",
    "effect": "4.0.0-beta.60",
    "typescript": "6.0.3"
  }
}
