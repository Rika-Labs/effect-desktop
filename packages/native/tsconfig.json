{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": true,
    "plugins": [
      {
        "name": "@effect/language-service",
        "diagnostics": false,
        "quickinfo": true,
        "completions": true,
        "goto": true,
        "renames": true
      }
    ]
  },
  "include": ["src"]
}
