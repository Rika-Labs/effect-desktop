{
  "name": "@effect-desktop/native",
  "version": "2.0.0",
  "private": true,
  "description": "TypeScript-facing native desktop services backed by the Effect Desktop host.",
  "license": "MIT OR Apache-2.0",
  "author": "Rika Labs, LLC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rika-Labs/effect-desktop.git",
    "directory": "packages/native"
  },
  "homepage": "https://github.com/Rika-Labs/effect-desktop#readme",
  "bugs": {
    "url": "https://github.com/Rika-Labs/effect-desktop/issues"
  },
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./contracts": {
      "types": "./src/contracts/index.ts",
      "default": "./src/contracts/index.ts"
    },
    "./protocol": {
      "types": "./src/protocol.ts",
      "default": "./src/protocol.ts"
    }
  },
  "scripts": {
    "check": "tsgo --singleThreaded --noEmit -p tsconfig.json",
    "typecheck": "tsgo --singleThreaded --noEmit -p tsconfig.json",
    "test": "bun test",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@effect-desktop/bridge": "workspace:*",
    "@effect-desktop/config": "workspace:*",
    "@effect-desktop/core": "workspace:*",
    "effect": "4.0.0-beta.69"
  }
}
