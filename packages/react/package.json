{
  "name": "@effect-desktop/react",
  "version": "2.0.0",
  "private": true,
  "description": "React provider and hooks for Effect Desktop renderer clients.",
  "license": "MIT OR Apache-2.0",
  "author": "Rika Labs, LLC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rika-Labs/effect-desktop.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/Rika-Labs/effect-desktop#readme",
  "bugs": {
    "url": "https://github.com/Rika-Labs/effect-desktop/issues"
  },
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./api": {
      "types": "./src/api.ts",
      "default": "./src/api.ts"
    },
    "./current-window": {
      "types": "./src/current-window.ts",
      "default": "./src/current-window.ts"
    },
    "./desktop": {
      "types": "./src/desktop.tsx",
      "default": "./src/desktop.tsx"
    },
    "./sql-pglite": {
      "types": "./src/sql-pglite.ts",
      "default": "./src/sql-pglite.ts"
    },
    "./storage/idb": {
      "types": "./src/storage/idb.ts",
      "default": "./src/storage/idb.ts"
    },
    "./storage/kv": {
      "types": "./src/storage/kv.ts",
      "default": "./src/storage/kv.ts"
    },
    "./windows": {
      "types": "./src/windows.ts",
      "default": "./src/windows.ts"
    }
  },
  "scripts": {
    "check": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@effect-desktop/bridge": "workspace:*",
    "@effect-desktop/core": "workspace:*",
    "@effect-desktop/native": "workspace:*",
    "@effect/platform-browser": "4.0.0-beta.60",
    "@effect/sql-sqlite-wasm": "4.0.0-beta.60",
    "@effect/wa-sqlite": "^0.1.2",
    "effect": "4.0.0-beta.60"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "optionalDependencies": {
    "@effect/sql-pglite": "4.0.0-beta.60",
    "@electric-sql/pglite": "^0.4.4"
  }
}
