---
import NotesIsland from "../components/NotesIsland"
import { NotesAstroIsland } from "../desktop"
import "../styles.css"

if (NotesAstroIsland.renderer !== "react") {
  throw new Error("Notes Astro example must hydrate through the React renderer")
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Effect Desktop Notes Astro</title>
  </head>
  <body>
    <NotesIsland client:only="react" />
  </body>
</html>
