{
  "name": "@effect-desktop/docs",
  "private": true,
  "description": "Deployable Next.js documentation site for Effect Desktop.",
  "license": "MIT OR Apache-2.0",
  "author": "Rika Labs, LLC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rika-Labs/effect-desktop.git",
    "directory": "apps/docs"
  },
  "homepage": "https://github.com/Rika-Labs/effect-desktop#readme",
  "bugs": {
    "url": "https://github.com/Rika-Labs/effect-desktop/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3001",
    "build": "fumadocs-mdx && next build",
    "check": "next typegen && fumadocs-mdx && tsc --noEmit -p tsconfig.json",
    "typecheck": "next typegen && fumadocs-mdx && tsc --noEmit -p tsconfig.json",
    "lint": "oxlint . --ignore-pattern '.next/**' --ignore-pattern '.source/**'",
    "deploy": "alchemy deploy",
    "destroy": "alchemy destroy"
  },
  "dependencies": {
    "fumadocs-core": "16.8.8",
    "fumadocs-mdx": "15.0.0",
    "fumadocs-ui": "16.8.8",
    "next": "16.2.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@effect/platform-bun": "4.0.0-beta.60",
    "@effect/platform-node": "4.0.0-beta.60",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "alchemy": "2.0.0-beta.36",
    "effect": "4.0.0-beta.60",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
