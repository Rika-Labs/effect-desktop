{
  "name": "effect-desktop-repo",
  "private": true,
  "description": "Bun-powered, Rust-hosted, React-friendly desktop application framework modeled through Effect.",
  "license": "MIT OR Apache-2.0",
  "author": "Rika Labs, LLC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rika-Labs/effect-desktop.git"
  },
  "homepage": "https://github.com/Rika-Labs/effect-desktop#readme",
  "bugs": {
    "url": "https://github.com/Rika-Labs/effect-desktop/issues"
  },
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "postinstall": "bun scripts/patch-effect-tsgo.ts",
    "prepare": "bun scripts/patch-effect-tsgo.ts",
    "desktop": "bun packages/cli/src/bin.ts",
    "build": "turbo build",
    "check": "bun run format:check && bun run lint:types && turbo check",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "lint": "ultracite check packages apps tests scripts --type-aware --type-check --deny-warnings --disable-nested-config --quiet",
    "lint:types": "bun run lint",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "cargo:check": "cargo check --workspace",
    "cargo:test": "cargo test --workspace",
    "cargo:clippy": "cargo clippy --workspace --all-targets -- -D warnings",
    "cargo:fmt": "cargo fmt --check"
  },
  "devDependencies": {
    "@effect/tsgo": "0.7.2",
    "@types/bun": "latest",
    "@typescript/native-preview": "7.0.0-dev.20260515.1",
    "effect": "4.0.0-beta.69",
    "oxfmt": "0.49.0",
    "oxlint": "1.64.0",
    "oxlint-tsgolint": "0.22.1",
    "turbo": "latest",
    "typescript": "latest",
    "ultracite": "7.7.0"
  }
}
