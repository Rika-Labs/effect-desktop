{
  "name": "effect-desktop-repo",
  "private": true,
  "description": "Bun-powered, Rust-hosted, React-friendly desktop application framework modeled through Effect.",
  "license": "MIT OR Apache-2.0",
  "author": "Rika Labs, LLC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rika-Labs/effect-desktop.git"
  },
  "homepage": "https://github.com/Rika-Labs/effect-desktop#readme",
  "bugs": {
    "url": "https://github.com/Rika-Labs/effect-desktop/issues"
  },
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "apps/examples/*",
    "packages/*",
    "templates/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "desktop": "bun packages/cli/src/bin.ts",
    "build": "turbo build",
    "check": "turbo check",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "lint": "turbo lint",
    "lint:types": "oxlint --type-aware --disable-nested-config --ignore-pattern '**/dist/**' --ignore-pattern '**/.next/**' --ignore-pattern '**/.astro/**' --ignore-pattern '**/.source/**' packages apps templates tests scripts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cargo:check": "cargo check --workspace",
    "cargo:test": "cargo test --workspace",
    "cargo:clippy": "cargo clippy --workspace --all-targets -- -D warnings",
    "cargo:fmt": "cargo fmt --check"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxlint": "latest",
    "oxlint-tsgolint": "latest",
    "prettier": "latest",
    "turbo": "latest",
    "typescript": "latest"
  }
}
